    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "description": "Repository owner",
        "x-mcp-header": "owner"
      },
      "page": {
        "type": "number",
        "description": "Page number for pagination (min 1)",
        "minimum": 1
      },
      "perPage": {
        "type": "number",
        "description": "Results per page for pagination (min 1, max 100)",
        "minimum": 1,
        "maximum": 100
      },
      "repo": {
        "type": "string",
        "description": "Repository name",
        "x-mcp-header": "repo"
      }
    },
    "required": [
